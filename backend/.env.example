# backend/.env としてコピーして使う（.env はgitignore対象）
ANTHROPIC_API_KEY=sk-ant-...
# /api/* の認証用共有 secret（クライアントは X-API-Secret ヘッダで送る）
# 16 文字以上 [A-Za-z0-9_-]。未設定・不正だと起動が exit 1 する
# 生成: openssl rand -base64 24 | tr -d '+/=' | head -c 24
API_SECRET=
PORT=8801
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_TRANSLATE_MODEL=claude-sonnet-5
# OCR結果（英語）のGemini TTS読み上げに使うAPIキー（未設定なら/api/ttsは失敗する）
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 単語イラスト生成（GPT Image 2）に使うAPIキー（未設定なら/api/word-illustrationは失敗する）
OPENAI_API_KEY=sk-proj-...
